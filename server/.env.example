PORT=5000
NODE_ENV=development

# Database (set one)
MONGODB_URI=mongodb://localhost:27017/portfolio
# DATABASE_URL=postgresql://user:pass@localhost:5432/portfolio

# Frontend origin for CORS
FRONTEND_URL=https://www.elitechwiz.site

# Admin API authentication (required for protected endpoints)
# Use a long random value. Provide either ADMIN_API_TOKEN or a comma-separated ADMIN_API_TOKENS list.
ADMIN_API_TOKEN=replace_with_a_long_random_token
# ADMIN_API_TOKENS=token_one,token_two

# Optional explicit main-admin token list (defaults to first ADMIN token if omitted)
# MAIN_ADMIN_API_TOKEN=replace_with_main_admin_token
# MAIN_ADMIN_API_TOKENS=main_token_one,main_token_two

# Cloudflare Turnstile secret (required in production for contact form)
TURNSTILE_SECRET=replace_with_turnstile_secret

# Public site URL (used for newsletter confirmation links)
SITE_URL=https://www.elitechwiz.site
