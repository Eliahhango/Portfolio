rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /admin/{allPaths=**} {
      allow read, write: if request.auth != null &&
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
