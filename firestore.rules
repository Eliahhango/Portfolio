rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: signed-in check
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: admin role check from users/{uid}
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'main', 'Admin', 'Main'];
    }
    
    // Users collection - admin only
    match /users/{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Posts collection - public read for published, full access for admin
    match /posts/{document=**} {
      allow read: if resource.data.published == true || isAdmin();
      allow write: if isAdmin();
    }

    // Projects collection - public read for published, full access for admin
    match /projects/{document=**} {
      allow read: if resource.data.published == true || isAdmin();
      allow write: if isAdmin();
    }

    // Services collection - public read for published, full access for admin
    match /services/{document=**} {
      allow read: if resource.data.published == true || isAdmin();
      allow write: if isAdmin();
    }
    
    // Visitors collection - admin only
    match /visitors/{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Activity log collection - admin only
    match /activities/{document=**} {
      allow read, write: if isAdmin();
    }

    // Settings collection - admin only
    match /settings/{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
